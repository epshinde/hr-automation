CODA_API_TOKEN=your_coda_api_token_here

EMAIL_USER=your_email_address@gmail.com
EMAIL_PASS=your_email_app_password_here

# IMAP inbox for reading incoming intern applications.
# Production target is careers@qpulse.tech on Titan (IMAP_HOST=imap.titan.email).
# Defaults below suit local testing against a spare Gmail (imap.gmail.com:993 over TLS).
# Gmail requires an app password (like EMAIL_PASS above), not your login password.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email_address@gmail.com
IMAP_PASS=your_email_app_password_here
# Optional: set to false only for a non-TLS/STARTTLS port. Defaults to true on port 993.
IMAP_TLS=true

# Optional: absolute path to a Google service account JSON key file.
# If omitted, the app looks for services/service-account.json.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
